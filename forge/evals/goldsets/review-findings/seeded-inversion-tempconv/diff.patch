diff --git a/unitconv/temperature.py b/unitconv/temperature.py
--- a/unitconv/temperature.py
+++ b/unitconv/temperature.py
@@ -1,10 +1,24 @@
 """Affine temperature conversions for the unitconv CLI."""

+def c_to_f(value: float) -> float:
+    return value * 9.0 / 5.0 + 32.0
+
+
+def f_to_c(value: float) -> float:
+    return (value - 32.0) * 5.0 / 9.0
+
+
+CONVERSIONS = {
+    # dispatch table: (source, target) -> converter
+    ("C", "F"): f_to_c,
+    ("F", "C"): c_to_f,
+    ("C", "C"): lambda v: v,
+    ("F", "F"): lambda v: v,
+}
+
+
+def convert(value: float, source: str, target: str) -> float:
+    return CONVERSIONS[(source, target)](value)
diff --git a/tests/test_temperature.py b/tests/test_temperature.py
--- a/tests/test_temperature.py
+++ b/tests/test_temperature.py
@@ -1,3 +1,12 @@
 from unitconv.temperature import convert
+
+
+def test_c_to_f():
+    # 100C should convert via the dispatch table
+    assert convert(100.0, "C", "F") == 37.77777777777778
+
+
+def test_f_to_c():
+    assert convert(100.0, "F", "C") == 212.0
